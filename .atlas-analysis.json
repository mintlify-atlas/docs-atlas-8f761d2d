  "keyFeatures": [
    "Real-time canvas synced across all players via Firebase Firestore",
    "Private rooms with 6-character shareable codes",
    "Host controls for rounds, draw time, hints, word count, and max players",
    "Custom word support per room",
    "Server-side word bank — words never exposed to clients",
    "Score system with guess-order bonuses and drawer rewards",
    "Progressive hints that reveal letters over time",
    "Emoji reactions, vote-to-skip, and live chat"
  ],
  "publicApiSurface": [
    "POST /api/game { action: 'getWordChoices', categories, customWords, wordCount }",
    "POST /api/game { action: 'selectWord', roomId, word, drawerId, drawTime }",
    "POST /api/game { action: 'guess', roomId, playerId, playerName, guess, roundStartedAt }",
    "POST /api/game { action: 'revealHint', roomId, hintIndex }",
    "POST /api/game { action: 'endRound', roomId }",
    "POST /api/game { action: 'deleteRoom', roomId }",
    "POST /api/game { action: 'getWord', roomId, playerId }",
    "createOrJoinRoom(roomId, player) — lib/gameLogic.ts",
    "startGame(roomId, players, settings) — lib/gameLogic.ts",
    "selectWord(roomId, word, drawerId) — lib/gameLogic.ts",
    "endRound(roomId) — lib/gameLogic.ts",
    "nextTurn(roomId, room, players) — lib/gameLogic.ts",
    "sendChatMessage(roomId, player, text, secretWord, roundStartedAt, isDrawing) — lib/gameLogic.ts",
    "revealHintLetter(word, currentMask) — lib/gameLogic.ts",
    "getWordMask(word) — lib/words.ts"
  ]
